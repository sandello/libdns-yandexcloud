# Yandex Cloud DNS credentials for live libdns tests.

# Required with YANDEXCLOUD_IAM_TOKEN. Optional with instance service account.
YANDEXCLOUD_FOLDER_ID=your-folder-id
YANDEXCLOUD_TEST_ZONE=example.com.

# Use exactly one authentication method.
YANDEXCLOUD_IAM_TOKEN=your-iam-token
YANDEXCLOUD_USE_INSTANCE_SERVICE_ACCOUNT=false
